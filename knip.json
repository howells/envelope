{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["src/**/*.ts", "index.ts"],
      "project": ["src/**/*.ts"],
      "ignore": ["**/*.test.ts"],
      "ignoreDependencies": [
        "husky",
        "ultracite",
        "lint-staged",
        "@biomejs/biome"
      ]
    },
    "playground": {
      "entry": ["src/**/*.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignore": ["**/*.d.ts", "**/*.config.{ts,mjs,js}"],
  "ignoreDependencies": ["@types/*", "typescript"]
}
